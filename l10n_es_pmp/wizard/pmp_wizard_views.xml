<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_l10n_es_pmp_wizard_form" model="ir.ui.view">
        <field name="name">l10n.es.pmp.wizard.form</field>
        <field name="model">l10n.es.pmp.wizard</field>
        <field name="arch" type="xml">
            <form string="Período Medio de Pago a Proveedores">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="pmp_paid"/>
                        <field name="pmp_pending"/>
                        <field name="pmp_total"/>
                    </group>
                </group>
                <footer>
                    <button name="action_compute" string="Calcular PMP" type="object"
                            class="btn-primary"/>
                    <button name="action_print_pdf" string="Exportar PDF" type="object"
                            class="btn-secondary" invisible="not line_ids"/>
                    <button name="action_export_excel" string="Exportar Excel" type="object"
                            class="btn-secondary" invisible="not line_ids"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
                <notebook>
                    <page string="Detalle" invisible="not line_ids">
                        <field name="line_ids" nolabel="1">
                            <list decoration-success="line_type == 'paid'"
                                  decoration-warning="line_type == 'pending'">
                                <field name="line_type" optional="show"/>
                                <field name="invoice_name"/>
                                <field name="partner_name"/>
                                <field name="invoice_date"/>
                                <field name="payment_date"/>
                                <field name="amount" sum="Total"/>
                                <field name="days" avg="Media días"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_l10n_es_pmp_wizard" model="ir.actions.act_window">
        <field name="name">Período Medio de Pago a Proveedores</field>
        <field name="res_model">l10n.es.pmp.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_l10n_es_pmp"
              name="P.M.P. Proveedores"
              parent="account.menu_finance_reports"
              action="action_l10n_es_pmp_wizard"
              sequence="99"/>

</odoo>
