<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_pmp_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Período Medio de Pago a Proveedores</h2>
                        <div class="row mt16 mb8">
                            <div class="col-6">
                                <strong>Empresa:</strong> <t t-out="o.company_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Período:</strong>
                                <t t-out="o.date_from"/> — <t t-out="o.date_to"/>
                            </div>
                        </div>
                        <div class="row mb16">
                            <div class="col-4">
                                <strong>Ratio pagos realizados:</strong>
                                <t t-out="'%.2f' % o.pmp_paid"/> días
                            </div>
                            <div class="col-4">
                                <strong>Ratio pagos pendientes:</strong>
                                <t t-out="'%.2f' % o.pmp_pending"/> días
                            </div>
                            <div class="col-4">
                                <strong>PMP Total:</strong>
                                <t t-out="'%.2f' % o.pmp_total"/> días
                            </div>
                        </div>
                        <table class="table table-sm table-bordered">
                            <thead class="table-dark">
                                <tr>
                                    <th>Estado</th>
                                    <th>Factura</th>
                                    <th>Proveedor</th>
                                    <th>Fecha Factura</th>
                                    <th>Fecha Pago Manual</th>
                                    <th>Fecha Pago Banco</th>
                                    <th class="text-end">Importe (€)</th>
                                    <th class="text-end">Días</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr>
                                        <td>
                                            <t t-if="line.line_type == 'paid'">Pagada</t>
                                            <t t-else="">Pendiente</t>
                                        </td>
                                        <td><t t-out="line.invoice_name"/></td>
                                        <td><t t-out="line.partner_name"/></td>
                                        <td><t t-out="line.invoice_date"/></td>
                                        <td><t t-out="line.payment_date_manual or '—'"/></td>
                                        <td><t t-out="line.payment_date or '—'"/></td>
                                        <td class="text-end">
                                            <t t-out="'%.2f' % line.amount"/>
                                        </td>
                                        <td class="text-end"><t t-out="line.days"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="5">Total</td>
                                    <td class="text-end">
                                        <t t-out="'%.2f' % sum(o.line_ids.mapped('amount'))"/>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                        <div class="mt16 text-muted small">
                            Calculado conforme a la Resolución ICAC y Ley 15/2010 de medidas de lucha contra la morosidad.
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_pmp" model="ir.actions.report">
        <field name="name">P.M.P. Proveedores</field>
        <field name="model">l10n.es.pmp.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_es_pmp.report_pmp_template</field>
        <field name="report_file">l10n_es_pmp.report_pmp_template</field>
        <field name="print_report_name">'PMP_Proveedores_%s_%s' % (object.date_from, object.date_to)</field>
    </record>

</odoo>
